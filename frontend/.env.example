# ========================================
# Firebase Configuration
# ========================================
# Get these from Firebase Console:
# 1. Go to https://console.firebase.google.com
# 2. Select your project
# 3. Click Settings (gear icon) > Project Settings
# 4. Copy values from "Your apps" section

VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# ========================================
# Socket.IO Configuration
# ========================================
# API is proxied through Nginx in Docker/EC2, so `/api` is the production default.
VITE_API_BASE_URL=/api

# Backend server URL for real-time messaging
# Leave blank to use the same domain as the frontend in production.
VITE_SOCKET_URL=

# ========================================
# OAuth Configuration (Optional)
# ========================================
# Google OAuth Client ID (NOT API Key)
# Get from: Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 IDs
# This must ALSO be added to Firebase Console > Authentication > Google
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Facebook App ID
# Get from: https://developers.facebook.com > Apps > Your App > Settings
# This must ALSO be added to Firebase Console > Authentication > Facebook
VITE_FACEBOOK_APP_ID=your_facebook_app_id

# ========================================
# IMPORTANT NOTES
# ========================================
# 1. API Key vs OAuth Client ID:
#    - VITE_FIREBASE_API_KEY is the Firebase Web API Key (starts with "AIza...")
#    - VITE_GOOGLE_CLIENT_ID is the Google OAuth Client ID (ends with ".apps.googleusercontent.com")
#    - They are DIFFERENT and have DIFFERENT purposes
#
# 2. Keep .env.local PRIVATE:
#    - Add .env.local to .gitignore
#    - NEVER commit API keys to version control
#    - The keys in .env.example are PLACEHOLDERS - replace with actual values
#
# 3. Setup Steps:
#    a) Create .env.local (copy from .env.example)
#    b) Get values from Firebase Console
#    c) For Google login: Also add Client ID to Firebase Console
#    d) For Facebook login: Also add App ID to Firebase Console
#    e) Set VITE_SOCKET_URL to your backend server URL
#    f) Restart dev server: npm run dev
#
# 4. If you get "auth/api-key-not-valid":
#    - Check that VITE_FIREBASE_API_KEY exists in .env.local
#    - Restart the dev server (Vite needs to reload env variables)
#    - Clear browser cache (Ctrl+Shift+Delete or Cmd+Shift+Delete)
#    - Check browser console for more error details
